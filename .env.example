# Copy this file to `.env` and fill in the providers you intend to use.
# The foundations/ layer needs NONE of these; the systems/ and frontier/
# layers read them from the environment. `.env` is git-ignored.

# Anthropic (Claude) — the systems/ layer's default provider (MASACT_MODEL)
ANTHROPIC_API_KEY=

# OpenAI (GPT)
OPENAI_API_KEY=

# Google (Gemini)
GOOGLE_API_KEY=

# Optional: tracing / observability (systems layer)
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
